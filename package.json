	"devDependencies": {
		"@amiceli/vitest-cucumber": "^7.0.0",
		"@biomejs/biome": "^2.5.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@vitejs/plugin-react": "^6.0.3",
		"@vitest/coverage-v8": "^4.1.9",
		"fast-check": "^4.8.0",
		"jsdom": "^29.1.1",
		"lefthook": "^2.1.9",

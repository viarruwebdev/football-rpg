{
	"name": "football-rpg",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc --noEmit && vite build",
		"preview": "vite preview",
		"type": "tsc --noEmit",
		"check": "biome check --write .",
